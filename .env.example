# BumbleAuto — ⚠️ fill in at least one API key

# Anthropic (JUDGE_BACKEND=anthropic) — best quality
ANTHROPIC_API_KEY=***

# Gemini (JUDGE_BACKEND=gemini) — cheap, good quality
GEMINI_API_KEY=***

# Discord webhook for session reports (optional)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Mode selection
ACTIVE_MODE=carlos

# Judge settings
JUDGE_BACKEND=gemini
GEMINI_MODEL=gemini-3.1-flash-lite

# Session limits
MAX_LIKES_PER_SESSION=20
SESSION_LIKE_MIN=0

# Run mode
DRY_RUN=false
