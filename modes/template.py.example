"""Template for a custom Bumble mode.

Copy this file to `modes/<your_name>.py`, edit the fields below, then set
`ACTIVE_MODE = "<your_name>"` in config.py (or pass `--mode <your_name>`
on the command line).

Every mode file MUST export NAME and PREFERENCES. The rest are optional.
"""

# Short identifier shown in logs.
NAME = "my_mode"

# One-line summary.
DESCRIPTION = "Describe your rubric in a sentence."

# Optional age gate.
AGE_MIN = None  # e.g. 22
AGE_MAX = None  # e.g. 34

# Optional per-mode caps. None = inherit config defaults.
MAX_LIKES_PER_SESSION = None
MAX_PROFILES_PER_SESSION = None

# The judging rubric. The judge sees this verbatim as part of its system
# prompt. Write clear instructions for what makes a RIGHT vs LEFT swipe.
PREFERENCES = """
Replace this with your own rubric. A useful structure:

  - State the default decision (SWIPE RIGHT or SWIPE LEFT).
  - List conditions that flip the default.
  - Note any special constraints.

See modes/example_lenient.py and modes/example_strict.py for examples.
"""
